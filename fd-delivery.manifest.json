{
  "version": "4",
  "installer": {
    "repoUrl": "https://github.com/FutureDecade/fd-headless-wp-system.git",
    "repoBranch": "main",
    "remoteInstallScriptUrl": "https://raw.githubusercontent.com/FutureDecade/fd-headless-wp-system/main/scripts/remote-install.sh",
    "installPath": "/opt/fd-headless-wp-system"
  },
  "groups": [
    {
      "key": "images",
      "label": "镜像与仓库"
    },
    {
      "key": "credentials",
      "label": "凭据与证书"
    },
    {
      "key": "site",
      "label": "站点信息"
    },
    {
      "key": "release",
      "label": "版本与发布",
      "description": "默认情况下只展示需要用户填写的字段；这组预设字段应放在高级设置里。"
    }
  ],
  "domainSlots": [
    {
      "key": "frontend",
      "label": "前台域名",
      "envKey": "FRONTEND_DOMAIN",
      "sourceField": "primaryDomain",
      "required": true,
      "placeholder": "www.futuredecade.com"
    },
    {
      "key": "admin",
      "label": "后台域名",
      "envKey": "ADMIN_DOMAIN",
      "sourceField": "adminDomain",
      "required": true,
      "placeholder": "admin.futuredecade.com"
    },
    {
      "key": "ws",
      "label": "WS 域名",
      "envKey": "WS_DOMAIN",
      "sourceField": "wsDomain",
      "required": true,
      "placeholder": "ws.futuredecade.com"
    }
  ],
  "envFields": [
    {
      "key": "FRONTEND_IMAGE",
      "label": "Frontend Image",
      "type": "text",
      "scope": "preset",
      "required": true,
      "group": "images"
    },
    {
      "key": "WEBSOCKET_IMAGE",
      "label": "WebSocket Image",
      "type": "text",
      "scope": "preset",
      "required": true,
      "group": "images"
    },
    {
      "key": "LETSENCRYPT_EMAIL",
      "label": "证书通知邮箱",
      "type": "email",
      "scope": "user_input",
      "required": true,
      "group": "credentials"
    },
    {
      "key": "ACR_USERNAME",
      "label": "ACR 用户名",
      "type": "text",
      "scope": "preset",
      "required": true,
      "group": "credentials"
    },
    {
      "key": "WORDPRESS_TITLE",
      "label": "站点名称",
      "type": "text",
      "scope": "user_input",
      "required": true,
      "group": "site"
    },
    {
      "key": "WORDPRESS_FETCH_RELEASE_ASSETS",
      "label": "自动拉取 WordPress Release 资产",
      "type": "boolean",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": true,
      "group": "release"
    },
    {
      "key": "WORDPRESS_RUN_INIT",
      "label": "自动执行 WordPress 首次初始化",
      "type": "boolean",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": true,
      "group": "release"
    },
    {
      "key": "WORDPRESS_RELEASE_OWNER",
      "label": "WordPress Release Owner",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "FutureDecade",
      "group": "release"
    },
    {
      "key": "FD_THEME_RELEASE_TAG",
      "label": "fd-theme Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v1.1.0",
      "group": "release"
    },
    {
      "key": "FD_PAGE_COMPOSER_RELEASE_TAG",
      "label": "fd-page-composer Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v0.2.0",
      "group": "release"
    },
    {
      "key": "FD_ADMIN_UI_RELEASE_TAG",
      "label": "fd-admin-ui Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v1.3.2",
      "group": "release"
    },
    {
      "key": "FD_MEMBER_RELEASE_TAG",
      "label": "fd-member Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v1.0.5",
      "group": "release"
    },
    {
      "key": "FD_PAYMENT_RELEASE_TAG",
      "label": "fd-payment Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v1.0.2",
      "group": "release"
    },
    {
      "key": "FD_COMMERCE_RELEASE_TAG",
      "label": "fd-commerce Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v1.0.0",
      "group": "release"
    },
    {
      "key": "FD_CONTENT_TYPES_RELEASE_TAG",
      "label": "fd-content-types Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v0.4.4",
      "group": "release"
    },
    {
      "key": "FD_FORMS_RELEASE_TAG",
      "label": "fd-forms Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v0.1.0",
      "group": "release"
    },
    {
      "key": "FD_AI_ROUTER_RELEASE_TAG",
      "label": "fd-ai-router Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v2.2.4",
      "group": "release"
    },
    {
      "key": "FD_WEBSOCKET_PUSH_RELEASE_TAG",
      "label": "fd-websocket-push Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v1.0.3",
      "group": "release"
    },
    {
      "key": "WPGRAPHQL_RELEASE_TAG",
      "label": "WPGraphQL Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v2.3.3-fd.1",
      "group": "release"
    },
    {
      "key": "WPGRAPHQL_JWT_AUTH_RELEASE_TAG",
      "label": "WPGraphQL JWT Auth Release Tag",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v0.7.2",
      "group": "release"
    },
    {
      "key": "WPGRAPHQL_TAX_QUERY_REF",
      "label": "WPGraphQL Tax Query Ref",
      "type": "text",
      "scope": "preset",
      "required": true,
      "editable": true,
      "advanced": true,
      "defaultValue": "v0.2.0",
      "group": "release"
    }
  ],
  "assets": [
    {
      "key": "fd-frontend-image",
      "label": "fd-frontend 镜像",
      "type": "docker_image",
      "required": true,
      "visibility": "private",
      "imageEnv": "FRONTEND_IMAGE",
      "authSecret": "ACR_PASSWORD",
      "group": "images",
      "description": "前台 Next.js 运行时镜像，由 fd-frontend 的 Delivery Image workflow 发布。"
    },
    {
      "key": "fd-websocket-image",
      "label": "fd-websocket 镜像",
      "type": "docker_image",
      "required": true,
      "visibility": "private",
      "imageEnv": "WEBSOCKET_IMAGE",
      "authSecret": "ACR_PASSWORD",
      "group": "images",
      "description": "WebSocket 推送服务镜像，由 fd-websocket 的 Publish Image workflow 发布。"
    },
    {
      "key": "fd-theme",
      "label": "fd-theme",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-theme",
      "tagEnv": "FD_THEME_RELEASE_TAG",
      "file": "fd-theme.zip",
      "path": "runtime/wp-content/themes/fd-theme",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-page-composer",
      "label": "fd-page-composer",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-page-composer",
      "tagEnv": "FD_PAGE_COMPOSER_RELEASE_TAG",
      "file": "fd-page-composer.zip",
      "path": "runtime/wp-content/plugins/fd-page-composer",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-admin-ui",
      "label": "fd-admin-ui",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-admin-ui",
      "tagEnv": "FD_ADMIN_UI_RELEASE_TAG",
      "file": "fd-admin-ui.zip",
      "path": "runtime/wp-content/plugins/fd-admin-ui",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-member",
      "label": "fd-member",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-member",
      "tagEnv": "FD_MEMBER_RELEASE_TAG",
      "file": "fd-member.zip",
      "path": "runtime/wp-content/plugins/fd-member",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-payment",
      "label": "fd-payment",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-payment",
      "tagEnv": "FD_PAYMENT_RELEASE_TAG",
      "file": "fd-payment.zip",
      "path": "runtime/wp-content/plugins/fd-payment",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-commerce",
      "label": "fd-commerce",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-commerce",
      "tagEnv": "FD_COMMERCE_RELEASE_TAG",
      "file": "fd-commerce.zip",
      "path": "runtime/wp-content/plugins/fd-commerce",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-content-types",
      "label": "fd-content-types",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-content-types",
      "tagEnv": "FD_CONTENT_TYPES_RELEASE_TAG",
      "file": "fd-content-types.zip",
      "path": "runtime/wp-content/plugins/fd-content-types",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-forms",
      "label": "fd-forms",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-forms",
      "tagEnv": "FD_FORMS_RELEASE_TAG",
      "file": "fd-forms.zip",
      "path": "runtime/wp-content/plugins/fd-forms",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-ai-router",
      "label": "fd-ai-router",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-ai-router",
      "tagEnv": "FD_AI_ROUTER_RELEASE_TAG",
      "file": "fd-ai-router.zip",
      "path": "runtime/wp-content/plugins/fd-ai-router",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "fd-websocket-push",
      "label": "fd-websocket-push",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/fd-websocket-push",
      "tagEnv": "FD_WEBSOCKET_PUSH_RELEASE_TAG",
      "file": "fd-websocket-push.zip",
      "path": "runtime/wp-content/plugins/fd-websocket-push",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "wp-graphql",
      "label": "WPGraphQL",
      "type": "github_release",
      "required": true,
      "visibility": "private",
      "repo": "FutureDecade/wp-graphql",
      "tagEnv": "WPGRAPHQL_RELEASE_TAG",
      "file": "wp-graphql.zip",
      "path": "runtime/wp-content/plugins/wp-graphql",
      "authSecret": "GH_TOKEN",
      "group": "release"
    },
    {
      "key": "wp-graphql-jwt-authentication",
      "label": "WPGraphQL JWT Authentication",
      "type": "github_release",
      "required": true,
      "visibility": "public",
      "repo": "wp-graphql/wp-graphql-jwt-authentication",
      "tagEnv": "WPGRAPHQL_JWT_AUTH_RELEASE_TAG",
      "file": "wp-graphql-jwt-authentication.zip",
      "path": "runtime/wp-content/plugins/wp-graphql-jwt-authentication",
      "group": "release"
    },
    {
      "key": "wp-graphql-tax-query",
      "label": "WPGraphQL Tax Query",
      "type": "github_release",
      "required": true,
      "visibility": "public",
      "repo": "wp-graphql/wp-graphql-tax-query",
      "tagEnv": "WPGRAPHQL_TAX_QUERY_REF",
      "path": "runtime/wp-content/plugins/wp-graphql-tax-query-develop",
      "group": "release",
      "description": "当前脚本以仓库归档方式下载，不依赖 Release asset 文件名。"
    }
  ],
  "secretFields": [
    {
      "key": "ACR_PASSWORD",
      "label": "ACR 密码",
      "type": "secret",
      "scope": "preset",
      "required": true,
      "group": "credentials"
    },
    {
      "key": "GH_TOKEN",
      "label": "FutureDecade 交付资产读取 Token",
      "description": "用于一键部署时从 FutureDecade GitHub Release 下载主题和插件资产。建议使用专用机器账号的 fine-grained PAT，仅授予交付资产仓库 Contents: Read-only 权限；这不是目标服务器 Token，也不是 fd-core-stack 仓库 Token。",
      "type": "secret",
      "scope": "preset",
      "required": true,
      "group": "credentials"
    }
  ],
  "notes": [
    "This manifest is the canonical delivery contract for the FutureDecade delivery repo.",
    "Only user_input fields should be shown by default in fd-core-stack."
  ]
}
